":1},"end":{"line":15,"column":1}},"key":"UT9vWgNLEz","urlSource":"https://cdn.prod.website-files.com/645cec60ffb18d5ebb37da4b/66ed74f05845f4fe0c578e55_656f49611e75aa3aefadff9a_overview.jpeg"},{"type":"thematicBreak","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"qxTvhxX9it"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"The atrous separable convolution, a central innovation in DeepLabV3+, melds atrous convolution with depthwise separable convolution.\n","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"HweFWqfrev"},{"type":"image","url":"/222c26327d63cc56ca282c8d946567f4.jpeg","alt":"An image","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"QRohEIxRyp","urlSource":"https://cdn.prod.website-files.com/645cec60ffb18d5ebb37da4b/66ed74f05845f4fe0c578e5f_656f495956b8c4fbf07c0fec_atrous_conv.jpeg"}],"key":"DgLLbQyTj7"},{"type":"thematicBreak","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"dw5G8YNZ4i"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"inlineCode","value":"test                                       ","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"Jpeh2IsA9L"}],"key":"B5fbz9TXQO"}],"key":"UgxsnN3StL"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"children":[{"type":"text","value":"III. how to set it up","key":"hPsyNjnP7a"}],"identifier":"iii-how-to-set-it-up","label":"III. how to set it up","html_id":"iii-how-to-set-it-up","implicit":true,"key":"QFu4YO8V5w"}],"key":"ydODFCDvZH"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"python","value":"model = seg_models.deeplabv3_resnet101(\n    weights=seg_models.DeepLabV3_ResNet101_Weights.DEFAULT ## taking the a pretrained model from the segmentat